{
  "expo": {
    "name": "Magnify",
    "slug": "magnify",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B3A6B"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.magnify.stakes"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1B3A6B",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "package": "com.magnify.stakes"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "name": "Magnify",
      "shortName": "Magnify",
      "description": "Stake Callings Workflow",
      "themeColor": "#1B3A6B",
      "backgroundColor": "#1B3A6B",
      "display": "standalone",
      "orientation": "portrait"
    },
    "plugins": []
  }
}
